<div class="app-layout">

  <%= render "shared/sidebar" %>

  <main class="feed">
    <header class="feed-header">
      <button type="button" class="feed-tab active">Para você</button>
      <button type="button" class="feed-tab">Seguindo</button>
    </header>

    <% @tweets.each do |tweet| %>
      <article class="tweet-card">
        <div class="tweet-card__header">
          <div class="tweet-author">
            <span class="post-avatar"><%= tweet.user.username.to_s.first.to_s.upcase %></span>
            <div class="tweet-author__meta">
              <strong class="tweet-author__name"><%= tweet.user.username %></strong>
              <span class="tweet-author__nick">@<%= tweet.user.nickname %></span>
            </div>
          </div>

          <% if tweet.user == current_user %>
            <%= button_to "Delete", tweet_path(tweet), method: :delete, class: "delete-btn" %>
          <% end %>
        </div>

        <% if tweet.retweet %>
          <div class="retweet-box">
            <span class="retweet-label">Retweet</span>

            <div class="retweet-card">
              <div class="tweet-card__header tweet-card__header--compact">
                <div class="tweet-author">
                  <span class="post-avatar"><%= tweet.retweet.user.username.to_s.first.to_s.upcase %></span>
                  <div class="tweet-author__meta">
                    <strong class="tweet-author__name"><%= tweet.retweet.user.username %></strong>
                  </div>
                </div>
              </div>

              <%= link_to tweet_path(tweet.retweet), class: "tweet-link" do %>
                <p class="tweet-body"><%= tweet.retweet.body %></p>

                <% if tweet.retweet.image.attached? %>
                  <%= image_tag tweet.retweet.image, class: "tweet-media" %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% else %>
          <%= link_to tweet_path(tweet), class: "tweet-link" do %>
            <p class="tweet-body"><%= tweet.body %></p>

            <% if tweet.image.attached? %>
              <%= image_tag tweet.image, class: "tweet-media" %>
            <% end %>
          <% end %>
        <% end %>

        <div class="tweet-actions">
          <span class="likes-count">❤️ <%= tweet.likes.count %></span>
          <%= button_to "Curtir", like_tweet_path(tweet), method: :post, class: "action-btn" %>

          <span class="retweets-count"></span>
          <%= button_to "Retweet", retweet_path(tweet), method: :post, class: "action-btn" %>

          <span class="comments-count"></span>
          <%= button_to "Comentarios", like_tweet_path(tweet), method: :post, class: "action-btn" %>
        </div>
        </article>
    <% end %>
  </main>
</div>

<%= link_to new_tweet_path, class: "fab", title: "Criar novo post" do %>
  <p>+</p>
<% end %>

<style>
  .menu-modal {
    display: none;
    position: sticky;
    top: 20px;
    height: fit-content;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 16px;
  }

  .app-layout {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
    padding: 20px;
  }

  .left-nav {
    position: sticky;
    top: 20px;
    height: fit-content;
    border-radius: 16px;
    padding: 16px;
  }

  .left-top {
    position: sticky;
    top: 20px;
    height: fit-content;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 16px;
  }

  .profile-config {
    height: fit-content;
    padding: 16px;
    margin-top: 15px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    position: sticky;
    top: 20px;
  }

  .logo {
    margin: 0 0 16px;
    font-size: 1.4rem;
  }

  .menu {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .menu-item {
    text-decoration: none;
    color: var(--text);
    padding: 10px 12px;
    border-radius: 999px;
    font-weight: 600;
  }

  .menu-item:hover {
    background: #e8f5fe;
    color: var(--primary);
  }

  .menu-item.active {
    background: #e8f5fe;
    color: var(--primary);
  }

  .feed {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .feed-header {
    display: flex;
    justify-content: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(6px);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .feed-tab {
    border: 0;
    background: transparent;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 700;
    padding: 10px 16px;
    border-radius: 999px;
    cursor: pointer;
  }

  .feed-tab.active {
    color: var(--text);
    background: #eff3f4;
  }

  .tweet-card {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }

  .tweet-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .tweet-card__header--compact {
    margin-bottom: 8px;
  }

  .tweet-author {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .tweet-author__meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .tweet-author__name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tweet-author__nick {
    color: #536471;
    font-size: 13px;
  }

  .post-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #e8f5fe;
    color: var(--primary);
    font-weight: 800;
    text-transform: uppercase;
    flex: 0 0 auto;
  }

  .delete-btn {
    border: 0;
    background: transparent;
    color: #e11d48;
    font-weight: 700;
    cursor: pointer;
  }

  .tweet-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .tweet-body {
    margin: 0 0 12px;
    line-height: 1.5;
    word-break: break-word;
  }

  .tweet-media {
    display: block;
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: 16px;
    margin-top: 12px;
  }

  .retweet-box {
    margin-top: 12px;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: #fafcff;
  }

  .retweet-label {
    display: inline-flex;
    margin-bottom: 10px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary);
  }

  .retweet-card {
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: #fff;
  }

  .tweet-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
  }

  .likes-count {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .action-btn {
    border: 1px solid #cfd9de;
    background: transparent;
    color: var(--muted);
    border-radius: 999px;
    padding: 6px 14px;
    font-weight: 600;
    cursor: pointer;
  }

  .action-btn:hover {
    background: #eff3f4;
    color: var(--text);
  }

  .fab {
    position: fixed;
    right: 28px;
    bottom: 28px;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    text-decoration: none;
    text-align: center;
    box-shadow: 0 8px 24px rgba(29, 155, 240, 0.35);
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .fab p {
    font-size: 2rem;
    margin: 0;
  }

  .fab:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .app-layout {
      grid-template-columns: 1fr;
    }

    .left-nav {
      position: static;
    }
  }
</style>