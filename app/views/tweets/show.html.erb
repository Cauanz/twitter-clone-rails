<section class="tweet-show">
  <article class="tweet-card">
    <div class="tweet-header">
      <div class="user-info">
        <div class="user-avatar"><%= @tweet.user.username %></div>
        <div class="user-details">
          <h3 class="user-name"><%= @tweet.user.username %></h3>
          <p class="tweet-date"><%= time_ago_in_words(@tweet.created_at) %> atrás</p>
        </div>
      </div>
    </div>

    <p class="tweet-body"><%= @tweet.body %></p>

    <% if @tweet.image.attached? %>
      <div class="tweet-image">
        <%= image_tag @tweet.image %>
      </div>
    <% end %>

    <div class="tweet-stats">
      <span class="stat">
        <span class="likes-count">❤️ <%= @tweet.likes.count %> </span>
        <%= button_to "Curtir", like_tweet_path(@tweet), method: :post, class: "like-btn" %>
      </span>
    </div>

    <nav class="tweet-actions" aria-label="Ações do tweet">
      <% if @tweet.user == current_user %>
        <%= link_to "✏️ Editar", edit_tweet_path(@tweet), class: "btn btn-primary" %>
        <%= link_to "🗑️ Deletar", tweet_path(@tweet), method: :delete, data: { confirm: "Tem certeza?" }, class: "btn btn-danger" %>
      <% end %>
      <%= link_to "← Voltar", tweets_path, class: "btn btn-secondary" %>
    </nav>
  </article>
</section>

<style>
  
  .tweet-show {
    display: flex;
    justify-content: center;
    padding: 40px 16px;
    background: #e6ecf0;
    min-height: 100vh;
  }

  .tweet-card {
    width: 100%;
    max-width: 600px;
    background: #fff;
    border: 1px solid #e1e8ed;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .tweet-body {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #14171a;
    margin-bottom: 20px;
    word-break: break-word;
  }

  .tweet-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .tweet-image {
    width: 100%;
  }

  img {
    width: 100%;
  }

  .btn {
    display: inline-block;
    padding: 10px 16px;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: #1da1f2;
    color: #fff;
  }

  .btn-primary:hover {
    background: #1991da;
  }

  .btn-secondary {
    background: #f5f8fa;
    color: #14171a;
    border: 1px solid #cfd9de;
  }

  .btn-secondary:hover {
    background: #e8f5fe;
  }


  .likes-count {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .like-btn {
    border: 1px solid #cfd9de;
    background: transparent;
    color: var(--muted);
    border-radius: 999px;
    padding: 6px 14px;
    font-weight: 600;
    cursor: pointer;
  }

  .like-btn:hover {
    background: #eff3f4;
    color: var(--text);
  }
</style>